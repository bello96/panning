{
  "name": "maze-gold-rush",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "cd worker && wrangler dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:worker": "cd worker && wrangler deploy",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=panning",
    "deploy:all": "npm run deploy:worker && npm run deploy:pages"
  },
  "dependencies": {
    "@twind/core": "^1.1.3",
    "@twind/preset-autoprefix": "^1.0.7",
    "@twind/preset-tailwind": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
